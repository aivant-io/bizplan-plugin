  // ============================================================================
  // DERIVED / COMPUTED OUTPUTS (Excel Writer calculates these, not reads)
  // ============================================================================
  "derived_metrics": {
    "description": "These are computed by Excel Writer from the raw outputs above, not read from cells. All formulas are deterministic — no reasoning required.",
    "metrics": {
      "revenue_cagr": {
        "label": "Revenue CAGR (Year 1 to Year 6)",
        "formula": "((net_revenue_year_6 / net_revenue_year_1) ^ (1/5)) - 1"
      },
      "break_even_year": {
        "label": "Break-Even Year",
        "formula": "First year where net_income > 0 (or null if never profitable)"
      },
      "runway_months": {
        "label": "Runway (months from Year 1 cash)",
        "formula": "If burn_rate_year_1 < 0: closing_cash_year_1 / abs(burn_rate_year_1 / 12), else null"
      }
    }
  }
}
