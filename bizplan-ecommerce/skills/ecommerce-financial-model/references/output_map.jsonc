{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Output Map",
  "description": "Maps output metrics to Excel cell addresses for reading. Used by Excel Writer to extract model outputs for the Plan Writer. All output cells are on the Model sheet. Column E = 2026 (Year 1), F = 2027, G = 2028, H = 2029, I = 2030, J = 2031.",
  "default_sheet": "Model",

  // ============================================================================
  // YEAR HEADERS
  // ============================================================================
  "years": {
    "description": "Forecast years in columns E through J",
    "cells": {
      "year_1": "E2",
      "year_2": "F2",
      "year_3": "G2",
      "year_4": "H2",
      "year_5": "I2",
      "year_6": "J2"
    }
  },

  // ============================================================================
  // ORDERS & TRAFFIC
  // ============================================================================
  "orders": {
    "total_visits": {
      "label": "Total Annual Site Visits",
      "type": "int",
      "cells": {
        "year_1": "E24",
        "year_2": "F24",
        "year_3": "G24",
        "year_4": "H24",
        "year_5": "I24",
        "year_6": "J24"
      }
    },
    "new_orders": {
